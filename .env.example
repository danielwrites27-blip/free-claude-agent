# === API Keys (Get free keys) ===
# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Optional: OpenRouter fallback (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=your_openrouter_key_here

# === Agent Configuration ===
# Daily token budget (free tier safety)
DAILY_TOKEN_LIMIT=50000

# Model routing thresholds
ROUTING_SIMPLE_TOKEN_THRESHOLD=200
ROUTING_REASONING_KEYWORDS=why,how,analyze,compare,explain,debug

# Caveman mode (compress outputs)
CAVEMAN_MODE=true

# Memory settings
MEMORY_PATH=agent_memory.mv2
MEMORY_MAX_TOKENS_PER_QUERY=1000

# === Hugging Face Spaces (for deployment) ===
# Set these in GitHub Secrets/Vars, not here
# HF_TOKEN=your_hf_token
# HF_USERNAME=your_hf_username
# SPACE_NAME=free-claude-agent
